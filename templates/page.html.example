<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}}</title>
    {{description}}
    {{canonical}}
    {{ogTitle}}
    {{ogDescription}}
    {{ogType}}
    {{ogUrl}}
    {{ogImage}}
    {{keywords}}
    {{robots}}
    {{jsonLd}}
    <link rel="stylesheet" href="/assets/site.css" />
  </head>
  <body>
    <main>{{body}}</main>
  </body>
</html>
